tmuxdev() {
    if ! command -v tmux >/dev/null 2>&1; then
        echo "tmux is not installed"
        return 1
    fi

    local session="${1:-${PWD##*/}}"
    if [[ -z $session ]]; then
        session="root"
    fi

    local dir="$PWD"
    local specs=(
        "claude:claude"
        "codex:codex"
        "gemini:gemini"
        "cursor-agent:agent"
        "copilot:copilot"
    )
    local available_specs=()
    local spec
    local window
    local cmd
    local created_session=0

    for spec in "${specs[@]}"; do
        window="${spec%%:*}"
        cmd="${spec#*:}"
        if command -v "$cmd" >/dev/null 2>&1; then
            available_specs+=("$spec")
        fi
    done

    local first_window="$session"
    if [[ ${#available_specs[@]} -gt 0 ]]; then
        first_window="${available_specs[1]%%:*}"
    fi

    if ! tmux has-session -t "$session" 2>/dev/null; then
        tmux new-session -d -s "$session" -n "$first_window" -c "$dir"
        created_session=1
    fi

    for spec in "${available_specs[@]}"; do
        window="${spec%%:*}"
        cmd="${spec#*:}"

        if ! tmux list-windows -t "$session" -F "#{window_name}" | grep -Fxq "$window"; then
            tmux new-window -t "$session" -n "$window" -c "$dir"
            tmux send-keys -t "$session:$window" "$cmd" C-m
        elif [[ $created_session -eq 1 && "$window" == "$first_window" ]]; then
            tmux send-keys -t "$session:$window" "$cmd" C-m
        fi
    done

    if [[ -n "${TMUX:-}" ]]; then
        tmux switch-client -t "$session"
    else
        tmux attach-session -t "$session"
    fi
}
